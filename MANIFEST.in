global-exclude .DS_Store
global-exclude */__pycache__/*

include *.txt
include CHANGELOG.md
include CODEOWNERS
recursive-include dataprofiler *.avro
recursive-include dataprofiler *.csv
recursive-include dataprofiler *.html
recursive-include dataprofiler *.json
recursive-include dataprofiler *.md
recursive-include dataprofiler *.parq
recursive-include dataprofiler *.parquet
recursive-include dataprofiler *.py
recursive-include dataprofiler *.txt

recursive-include dataprofiler/resources *.json
recursive-include dataprofiler/resources *.pb
recursive-include dataprofiler/resources *.py
recursive-include dataprofiler/resources *.keras

recursive-include dataprofiler/labelers/embeddings *.txt
include versioneer.py
include dataprofiler/_version.py
include .whitesource

recursive-exclude _docs *.html
recursive-exclude _docs *.cfg
exclude _docs/LICENSE
recursive-exclude _docs *.md
recursive-exclude _docs *.nojekyll
recursive-exclude _docs *.png
recursive-exclude _docs *.py
recursive-exclude _docs *.rst
recursive-exclude _docs Makefile
